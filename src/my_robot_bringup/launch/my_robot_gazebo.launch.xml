<launch>
    <let name="urdf_path"
         value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro" />
        
    <let name="rviz_config_path"
         value="$(find-pkg-share my_robot_description)/rviz/robot_arm_config.rviz"/>

    <let name="gazebo_config_path"
         value="$(find-pkg-share my_robot_bringup)/config/gazebo_bridge.yaml" />


    <!-- robot_state_publisher-->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />  <!-- runs xacro, gets the URDF, and gives it to robot_state_publisher.-->
    </node>
    
    <!-- gazebo simulator-->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(find-pkg-share my_robot_bringup)/worlds/test_world.sdf -r"/>   <!--spawning in custom made world-->
        <!-- <arg name="gz_args" value="empty.sdf -r"/> -->
    </include>
    

    <!-- spawn robot-->
    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description -name my_robot" />


    <!-- gazebo bridge-->
    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>


    <!-- rviz-->
    <node pkg="rviz2" exec="rviz2" output="screen"
          args="-d $(var rviz_config_path)"/>
</launch>













